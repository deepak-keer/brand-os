PORT=5000
NODE_ENV=development

# Behind a load balancer (Docker/Railway/Render/Fly). Default 1. If rate-limit still errors on X-Forwarded-For, try 2.
# TRUST_PROXY_HOPS=2

# MongoDB
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/brandos?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_long_random_secret_at_least_32_chars
JWT_REFRESH_SECRET=another_super_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AI
GROQ_API_KEY=your_groq_api_key_from_console.groq.com
GROQ_MODEL=openai/gpt-oss-20b

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS
CLIENT_URL=https://creaters-brand-os.vercel.app
# Comma-separated; required if the Vite app on localhost calls this API in production (Railway)
# CORS_EXTRA_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LOGO_URL=https://creaters-brand-os.vercel.app/logo.png

# Email (Resend — https://resend.com )
RESEND_API_KEY=re_xxxxxxxx
# onboarding@resend.dev = sandbox: you can ONLY send to your Resend account email until you verify a domain.
# After verifying a domain at resend.com/domains, set FROM_EMAIL to e.g. noreply@yourdomain.com to mail any recipient.
FROM_EMAIL=onboarding@resend.dev
FROM_NAME=Personal Brand OS
